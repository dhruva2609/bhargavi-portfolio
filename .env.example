# --- SANCTUARY PRODUCTION ENVIRONMENT ---

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/bhargavi_portfolio

# Secret passphrase for the Creator Studio
CREATOR_KEY=your_secret_passphrase_here

# Frontend Production URL (used for CORS hardening)
# e.g., https://bhargavi-portfolio.vercel.app or https://bhargavi.studio
PRODUCTION_URL=http://localhost:5173

# Port for the server (Production usually provides this automatically)
PORT=5000

# Node Environment (production/development)
NODE_ENV=production

# Email Service Configuration (Nodemailer - Gmail)
# Create an App Password for Gmail for secure access
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_RECEIVER=receiver_email@gmail.com
